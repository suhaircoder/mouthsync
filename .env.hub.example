# Copy to your shell before publishing workers:
#   export DOCKER_USER=your_docker_hub_username
#
# Optional:
#   export DOCKER_TAG=latest
#   export DOCKER_PLATFORM=linux/amd64
#
# Stage 1 — SadTalker GPU worker:
#   make worker-sadtalker-publish
#
# Stage 2 — Wav2Lip GPU worker:
#   make worker-wav2lip-publish
#
# Both:
#   make worker-publish-ready
