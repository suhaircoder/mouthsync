# MongoDB (history, user settings from UI)
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=mouthsync

# Optional default worker URL (can set in UI at localhost:3000 instead of .env).
# No trailing slash.
WORKER_URL=
# WORKER_URL=https://xxxxxxxx-8000.proxy.runpod.net

# If WORKER_API_KEY is set on the RunPod worker — use the same value here.
WORKER_API_KEY=

# Optional: gateway → worker HTTP timeout (seconds)
WORKER_TIMEOUT_SEC=600

# Face detection on portraits (gateway, OpenCV) before calling the worker
FACE_CHECK_ENABLED=1
FACE_REQUIRE_SINGLE=1
FACE_MIN_SIZE_RATIO=0.08
FACE_AUTO_CROP=1
PHOTO_MAX_EDGE=2048
PHOTO_BRIGHTNESS=1.0
PHOTO_CONTRAST=1.0
PHOTO_SHARPNESS=1.0
PHOTO_JPEG_QUALITY=92

# Audio prep on gateway before worker (delay, trim, gain, resample)
AUDIO_DELAY_MS=0
AUDIO_TRIM_SILENCE=0
AUDIO_TRIM_THRESHOLD_DB=-40
AUDIO_GAIN_DB=0
AUDIO_NORMALIZE_PEAK=0
AUDIO_MAX_DURATION_SEC=0
AUDIO_SAMPLE_RATE_HZ=0
AUDIO_FORCE_MONO=1
AUDIO_PLAYBACK_SPEED=1

# --- Local worker in Docker (no RunPod) ---
# WORKER_URL=http://worker:8000
# Then: docker compose --profile local-worker up --build
