# Optional default worker URL (can set in UI at localhost:3000 instead of .env).
# No trailing slash.
WORKER_URL=
# WORKER_URL=https://xxxxxxxx-8000.proxy.runpod.net

# If WORKER_API_KEY is set on the RunPod worker — use the same value here.
WORKER_API_KEY=

# Optional: gateway → worker HTTP timeout (seconds)
WORKER_TIMEOUT_SEC=600

# --- Local worker in Docker (no RunPod) ---
# WORKER_URL=http://worker:8000
# Then: docker compose --profile local-worker up --build
