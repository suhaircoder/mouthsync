# Variables for docker compose are set in mouthsync/.env at project root

MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=mouthsync

WORKER_URL=https://xxxxxxxx-8000.proxy.runpod.net
WORKER_API_KEY=
# Второй Pod: mouthsync-worker-wav2lip (POST /refine)
WAV2LIP_WORKER_URL=https://yyyyyyyy-8000.proxy.runpod.net
WAV2LIP_WORKER_API_KEY=
WORKER_TIMEOUT_SEC=600

# Photo prep defaults (overridden per request from UI form fields)
FACE_CHECK_ENABLED=1
FACE_REQUIRE_SINGLE=1
FACE_MIN_SIZE_RATIO=0.08
FACE_AUTO_CROP=1
PHOTO_MAX_EDGE=2048
PHOTO_BRIGHTNESS=1.0
PHOTO_CONTRAST=1.0
PHOTO_SHARPNESS=1.0
PHOTO_JPEG_QUALITY=92

# Audio prep defaults (overridden per request from UI form fields)
AUDIO_DELAY_MS=0
AUDIO_TRIM_SILENCE=0
AUDIO_TRIM_THRESHOLD_DB=-40
AUDIO_GAIN_DB=0
AUDIO_NORMALIZE_PEAK=0
AUDIO_MAX_DURATION_SEC=0
AUDIO_SAMPLE_RATE_HZ=0
AUDIO_FORCE_MONO=1
AUDIO_PLAYBACK_SPEED=1
